# ── Salad Cloud ──
# Get these at: https://portal.salad.com → API Keys / Organizations / Projects
SALAD_API_KEY=salad_xxxxxxxxxxxxxxxxxxxxxxxx
SALAD_ORG=grindy
SALAD_PROJECT=your-project-name
SALAD_IMAGE=ghcr.io/YOUR_USERNAME/poetry-trainer:latest

# ── HuggingFace ──
# Get at: https://huggingface.co/settings/tokens → New token (type: Read)
# Also accept the Qwen license: https://huggingface.co/Qwen/Qwen2.5-1.5B
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloud Storage (pick one) ──

# Option A: Google Cloud Storage
# Get at: https://console.cloud.google.com → Cloud Storage → Create bucket
# Service Account key: IAM → Service Accounts → Create → Storage Object Admin → JSON key
# Store key content as GCS_CREDENTIALS_JSON (single line, in quotes)
#GCS_BUCKET=gs://your-bucket/poetry-checkpoints
#GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}

# Option B: Cloudflare R2 (cheaper, $0.015/GB/month, no egress fees)
# Get at: https://dash.cloudflare.com → R2 → Create bucket
# Then: Manage R2 API Tokens → Create API Token → copy Access Key + Secret
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com  (found on R2 overview page)
S3_BUCKET=s3://poetry-checkpoints/training-runs
S3_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Option C: AWS S3
# Get at: https://aws.amazon.com → S3 → Create bucket
# IAM → Users → Create → AmazonS3FullAccess → copy Access Key + Secret
#S3_BUCKET=s3://your-bucket/poetry-checkpoints
#AWS_ACCESS_KEY_ID=AKIA...
#AWS_SECRET_ACCESS_KEY=...
