# ── Salad ──
SALAD_API_KEY=salad_xxx
SALAD_ORG=your-org-name
SALAD_PROJECT=your-project-name
SALAD_IMAGE=ghcr.io/YOUR_USER/poetry-trainer:latest

# ── HuggingFace ──
HF_TOKEN=hf_xxx

# ── Cloud Storage (pick one) ──

# Cloudflare R2 (recommended — $0.015/GB, zero egress)
S3_BUCKET=s3://poetry-checkpoints/training-runs
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your-r2-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-key

# OR: Google Cloud Storage
# GCS_BUCKET=gs://your-bucket/training-runs
# GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# OR: AWS S3
# AWS_DEFAULT_REGION=us-east-1

# ── Training (optional) ──
# AUTO_CHAIN_STAGES=1  # Run Stage 1 → Stage 2 in one container
