# PoetryDuel-GPT v5.1 Instruct — containerized for Salad GPU
FROM pytorch/pytorch:2.7.1-cuda12.8-cudnn9-runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    git build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python deps (trl + datasets for instruct training)
COPY src/finetune/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Corpus files (for backward compat — not used by instruct training)
COPY src/finetune/corpus/poetry_corpus.txt src/finetune/corpus/corpus_luc_bat.txt /app/corpus/

# Instruction-tuning data (pre-generated by preprocess_instruct.py)
COPY data/instruct_train.jsonl data/instruct_val.jsonl /app/data/

# Training code
COPY src/finetune/train_instruct.py /app/train.py
COPY src/finetune/entrypoint.sh /app/
RUN chmod +x /app/entrypoint.sh

ENV PYTHONUNBUFFERED=1
ENTRYPOINT ["/app/entrypoint.sh"]
